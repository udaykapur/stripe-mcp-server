{
  "name": "stripe-mcp",
  "version": "1.0.0",
  "description": "MCP server for Stripe payment operations",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stripe-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
